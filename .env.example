# Copy to .env in the project root (next to run.py) and edit if needed.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mindtrack_db

# Optional: comma-separated browser origins for CORS. If unset in development,
# only http://127.0.0.1:5500 (VS Code Live Server) is allowed. For production,
# set your real UI origins, e.g. CORS_ORIGINS=https://user.github.io
# CORS_ORIGINS=https://production.example.com,http://127.0.0.1:5500

# Optional: dev-only if Atlas TLS still fails with CERTIFICATE_VERIFY_FAILED (never in prod)
# MONGO_TLS_INSECURE=1

# Optional: enable uvicorn hot reload for backend/app + backend/fapi (can cause unstable API).
# Default python3 run.py runs without reload. Remove or comment out if you did not intend reload.
# UVICORN_RELOAD=1
