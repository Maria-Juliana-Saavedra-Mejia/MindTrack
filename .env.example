# Copy to .env in the project root (next to run.py) and edit if needed.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mindtrack_db

# --- One-line local dev (HTML in Chrome via Live Server on :5500, API on 5050–5059) ---
# Uncomment so the API sends Access-Control-Allow-Origin for http://127.0.0.1:5500 :
# FLASK_ENV=development

# If you set FLASK_ENV=production (or ENV=production) for a deployed API, you MUST set
# CORS_ORIGINS below — otherwise allow_origins is empty and the browser shows a CORS error
# (and Live Server at :5500 cannot call the API). For laptop-only dev with python run.py,
# leave FLASK_ENV unset or use development.

# Optional: comma-separated browser origins for CORS. If unset in development,
# only http://127.0.0.1:5500 and http://localhost:5500 (VS Code Live Server) are allowed.
# If CORS_ORIGINS is set but FLASK_ENV is development, those two Live Server origins are still
# added automatically so you can list only GitHub Pages here and still use Live Server locally.
# For production, set your real UI origins, e.g. CORS_ORIGINS=https://user.github.io
# CORS_ORIGINS=https://production.example.com,http://127.0.0.1:5500
#
# If FLASK_ENV=production but you still open the HTML from Live Server (:5500), either add
# the two Live Server origins to CORS_ORIGINS above, or set:
# MINDTRACK_MERGE_LIVE_SERVER_CORS=1

# Optional: dev-only if Atlas TLS still fails with CERTIFICATE_VERIFY_FAILED (never in prod)
# MONGO_TLS_INSECURE=1

# Optional: enable uvicorn hot reload for backend/app + backend/fapi (can cause unstable API).
# Default python3 run.py runs without reload. Remove or comment out if you did not intend reload.
# UVICORN_RELOAD=1
